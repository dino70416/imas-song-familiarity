{
  "name": "imas-song-familiarity",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && prisma migrate deploy && next build",
    "start": "next start",
    "lint": "eslint",
    "sync:idols": "ts-node --project scripts/tsconfig.json scripts/sync-idols.ts",
    "sync:units": "ts-node --project scripts/tsconfig.json scripts/sync-units.ts",
    "sync:songs": "ts-node --project scripts/tsconfig.json scripts/scrape.ts",
    "sync:pitches": "ts-node --project scripts/tsconfig.json scripts/update-pitches.ts",
    "sync:idol-images": "ts-node --project scripts/tsconfig.json scripts/sync-idol-images.ts",
    "fix:876": "ts-node --project scripts/tsconfig.json scripts/fix-876.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "axios": "^1.16.1",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "next": "16.2.6",
    "next-auth": "^4.24.14",
    "p-limit": "^7.3.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.19.41",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jsdom": "^29.1.1",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "vitest": "^4.1.6"
  }
}
