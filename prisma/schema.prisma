datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id         String          @id @default(uuid()) @db.Uuid
  username   String          @unique
  password   String
  nickname   String
  shareCode  String          @unique
  themeColor String          @default("#92cfbb")
  isPublic      Boolean         @default(false)
  isPublicPitchRange Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  selections    UserSelection[]
}

model Song {
  id           String          @id @default(uuid()) @db.Uuid
  slug         String          @unique // brand/id，例如 "ml/12087"
  title        String
  brand        String
  musicType    String
  lyrics       String?
  composer     String?
  arranger     String?
  lowestPitch  String?
  highestPitch String?
  youtubeIds   String?         // 公式動画的 YouTube video ID，多個以逗號分隔
  members      SongMember[]
  units        SongUnit[]
  selections   UserSelection[]

  @@index([brand])
}

model Member {
  id         String       @id @default(uuid()) @db.Uuid
  name       String       @unique
  cvName     String?
  taxId      Int?         @unique
  kana       String?
  cvKana     String?
  production String?      // cg | 765 | sc | 315 | gakuen | hatsuboshi | 876
  color      String?      // 主題代表色 (Hex)
  // 偶像縮圖的相對路徑（例：/idol-images/1.webp）。圖片本身存 public/idol-images/。
  // 只存路徑，不存 base64/blob，把 DB 體積壓到最小（~25 char/row）。
  imagePath  String?
  songs      SongMember[]
  units      UnitMember[]

  @@index([production])
}

model Unit {
  id         String       @id @default(uuid()) @db.Uuid
  taxId      Int          @unique
  name       String
  kana       String?
  production String?      // 派生：成員 production；跨 IP 為 "mixed"
  color      String?      // 組合代表色 (Hex)
  members    UnitMember[]
  songs      SongUnit[]

  @@index([production])
  @@index([name])
}

model UnitMember {
  unitId   String @db.Uuid
  memberId String @db.Uuid
  unit     Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@id([unitId, memberId])
}

model SongUnit {
  songId String @db.Uuid
  unitId String @db.Uuid
  song   Song @relation(fields: [songId], references: [id], onDelete: Cascade)
  unit   Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@id([songId, unitId])
}

model SongMember {
  songId   String @db.Uuid
  memberId String @db.Uuid
  song     Song   @relation(fields: [songId], references: [id], onDelete: Cascade)
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@id([songId, memberId])
}

model UserSelection {
  userId      String @db.Uuid
  songId      String @db.Uuid
  familiarity Int      // 1=會唱, 2=常聽/只聽, 3=有聽過, 4=不太記得
  updatedAt   DateTime @default(now()) @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  song        Song     @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@id([userId, songId])
}

model PitchToNumber {
  pitch      String @id
  scientific String
  number     Int    @unique
}

model UserVocalRange {
  userId             String @id @db.Uuid
  comfortableHighest Int?   // e.g. 47 (hiG)
  singableHighest    Int?   // e.g. 50 (hihiA#) (介在舒適與極限之間，能唱但不擅長)
  limitHighest       Int?   // e.g. 52 (hihiC)
  comfortableLowest  Int?   // e.g. 23 (mid1G)
  singableLowest     Int?   // e.g. 20 (mid1E) (介在舒適與極限之間，能唱但不擅長)
  limitLowest        Int?   // e.g. 16 (mid1C)
}

