datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id         String          @id @default(uuid())
  username   String          @unique
  password   String
  nickname   String
  shareCode  String          @unique
  themeColor String          @default("#92cfbb")
  isPublic   Boolean         @default(false)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  selections UserSelection[]
}

model Song {
  id           String          @id @default(uuid())
  slug         String          @unique // brand/id，例如 "ml/12087"
  title        String
  brand        String
  musicType    String
  lyrics       String?
  composer     String?
  arranger     String?
  lowestPitch  String?
  highestPitch String?
  youtubeIds   String?         // 公式動画的 YouTube video ID，多個以逗號分隔
  members      SongMember[]
  units        SongUnit[]
  selections   UserSelection[]

  @@index([brand])
}

model Member {
  id         String       @id @default(uuid())
  name       String       @unique
  cvName     String?
  taxId      Int?         @unique
  kana       String?
  cvKana     String?
  production String?      // cg | 765 | sc | 315 | gakuen | hatsuboshi | 876
  songs      SongMember[]
  units      UnitMember[]

  @@index([production])
}

model Unit {
  id         String       @id @default(uuid())
  taxId      Int          @unique
  name       String
  kana       String?
  production String?      // 派生：成員 production；跨 IP 為 "mixed"
  members    UnitMember[]
  songs      SongUnit[]

  @@index([production])
  @@index([name])
}

model UnitMember {
  unitId   String
  memberId String
  unit     Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@id([unitId, memberId])
}

model SongUnit {
  songId String
  unitId String
  song   Song @relation(fields: [songId], references: [id], onDelete: Cascade)
  unit   Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@id([songId, unitId])
}

model SongMember {
  songId   String
  memberId String
  song     Song   @relation(fields: [songId], references: [id], onDelete: Cascade)
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@id([songId, memberId])
}

model UserSelection {
  userId      String
  songId      String
  familiarity Int      // 1=會唱, 2=常聽/只聽, 3=有聽過, 4=不太記得
  updatedAt   DateTime @default(now()) @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  song        Song     @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@id([userId, songId])
}
